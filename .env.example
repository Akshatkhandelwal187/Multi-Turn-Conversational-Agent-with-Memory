# =============================================================================
# Aria configuration. Copy to `.env` and edit. All knobs are optional except the
# Hugging Face token (required only to talk to the real model). Variables use the
# ARIA_ prefix and map 1:1 onto aria.config.Settings.
# =============================================================================

# --- Hugging Face Inference API ---------------------------------------------
# Create a (Read) token at https://huggingface.co/settings/tokens
HUGGINGFACEHUB_API_TOKEN=hf_your_token_here

# Open-source instruct model. The default is openly accessible (no gating).
# Gated alternatives (accept terms on the model page first):
#   meta-llama/Llama-3.1-8B-Instruct
#   mistralai/Mistral-7B-Instruct-v0.3
ARIA_HF_MODEL=Qwen/Qwen2.5-7B-Instruct
# ARIA_TEMPERATURE=0.7
# ARIA_MAX_NEW_TOKENS=512

# --- Embeddings -------------------------------------------------------------
# 'hashing' = deterministic & offline (no torch). 'sentence_transformer' = real
# semantics at runtime (requires the [embeddings] extra: pip install -e .[embeddings]).
ARIA_EMBEDDER=sentence_transformer
# ARIA_ST_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# ARIA_VECTOR_BACKEND=numpy

# --- Memory ----------------------------------------------------------------
# ARIA_WORKING_WINDOW_MESSAGES=12
# ARIA_EPISODIC_TOP_K=4
# ARIA_RELEVANCE_WEIGHT=1.0
# ARIA_RECENCY_WEIGHT=1.0
# ARIA_IMPORTANCE_WEIGHT=1.0
# ARIA_RECENCY_HALF_LIFE_HOURS=24
# ARIA_SUMMARY_TOKEN_BUDGET=2000
# ARIA_REFLECTION_EVERY_K_TURNS=4

# --- Tools / RAG ------------------------------------------------------------
# ARIA_ENABLE_TOOLS=true
# ARIA_MAX_TOOL_ITERS=4
# ARIA_RAG_TOP_K=4

# --- Persistence & logging --------------------------------------------------
# ARIA_DATA_DIR=data
# ARIA_PERSIST=true
# ARIA_LOG_LEVEL=INFO
# ARIA_LOG_JSON=false
