# Hugging Face access token — https://huggingface.co/settings/tokens
# A "Read" token is sufficient. Required to call the Inference API.
HUGGINGFACEHUB_API_TOKEN=hf_your_token_here

# Open-source instruct model served via Hugging Face Inference Providers.
# The default below is openly accessible (no gating). Other options:
#   meta-llama/Llama-3.1-8B-Instruct    (gated — accept terms on the model page)
#   mistralai/Mistral-7B-Instruct-v0.3  (gated — accept terms on the model page)
HF_MODEL=Qwen/Qwen2.5-7B-Instruct
